# Orive Creative Studio environment keys
# Copy this file to .env and fill in real values. Never commit .env.
# .env is gitignored. Keys live here, never in agent files, skills, docs, or chat.

# Free stock images (default source). Get a free key at pexels.com/api
PEXELS_API_KEY=

# Optional alternative image sources, set up the same way
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=

# Google Analytics 4 (official route). Path to a service account JSON file
# and the GA4 property id. The service account needs Viewer access on the property.
GA4_SERVICE_ACCOUNT_JSON=
GA4_PROPERTY_ID=
